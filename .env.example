# ── Application ───────────────────────────────────────────────────────────────
# Bearer token / API key that clients must send as: X-API-Key: <value>
APP_API_KEY=change-me-before-use

# ── Encryption ────────────────────────────────────────────────────────────────
# Fernet symmetric key used to encrypt LLM provider API keys at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# KEEP THIS SECRET — rotating it requires re-encrypting all stored credentials.
FERNET_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (dev).  Swap to postgresql+asyncpg://... for production.
DATABASE_URL=sqlite+aiosqlite:///./opsintel.db

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Observability (optional) ──────────────────────────────────────────────────
# Set LANGSMITH_TRACING=true to stream LLM traces to LangSmith (next pass).
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=opsintel

# ── ServiceNow (next pass) ────────────────────────────────────────────────────
# SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
# SERVICENOW_USERNAME=
# SERVICENOW_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * in dev only.
CORS_ORIGINS=http://localhost:5173
